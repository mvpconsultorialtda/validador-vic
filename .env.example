# validador-vic — env vars runner central
# NUNCA committar este arquivo com valores reais — copie para .env

# ═══════════════════════════════════════════════════════
# LLM providers (free tiers) — rotator usa nessa ordem
# ═══════════════════════════════════════════════════════
# Gemini: https://aistudio.google.com/apikey · free 1500 req/dia · 1M contexto
GEMINI_KEYS=

# Groq: https://console.groq.com · free 100k tokens/dia
GROQ_KEYS=

# Cerebras: https://cloud.cerebras.ai · free 1M tokens/dia
CEREBRAS_KEYS=

# OpenRouter (fallback): https://openrouter.ai/keys · pool free
OPENROUTER_KEY=

# ═══════════════════════════════════════════════════════
# SaaS observing (só CI, upload de source maps etc)
# ═══════════════════════════════════════════════════════
# Sentry: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# PostHog: só se rodar sync programático — SDK client usa NEXT_PUBLIC_
POSTHOG_PROJECT_API_KEY=

# ═══════════════════════════════════════════════════════
# GitHub (opcional, pra abrir issue automática nightly)
# ═══════════════════════════════════════════════════════
# Personal Access Token com scope repo · https://github.com/settings/tokens
GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════
# TestSprite (opcional bootstrap 30 dias)
# ═══════════════════════════════════════════════════════
TESTSPRITE_API_KEY=
